# ============================================
# My State Manager — 环境变量模板
# ============================================
# 复制此文件为 .env.local 并填入你的 Supabase 凭证
# cp .env.example .env.local
#
# 注意：.env.local 已被 .gitignore 忽略，不会被提交到仓库
# ============================================

# Supabase 项目 URL（在 Supabase Dashboard → Settings → API 中获取）
VITE_SUPABASE_URL=your_supabase_project_url

# Supabase Publishable Key（anon key，前端安全可公开）
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key
